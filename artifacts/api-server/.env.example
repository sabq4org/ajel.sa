# api-server (Railway) — environment variables
#
# In Railway, set these as service variables. PORT is set automatically.

# Database (Railway Postgres connection string)
DATABASE_URL=postgresql://user:pass@host:port/db

# Auth — MUST match what ajelsa (Vercel) uses to sign cookies during the
# transition period, so a session minted by either side is verifiable on
# the other. 32+ random characters.
AUTH_SECRET=replace-with-32-or-more-random-characters

# Optional override for the session cookie name (default: ajel_session).
# AUTH_COOKIE_NAME=ajel_session

# Cross-origin cookie configuration (production):
#   FRONTEND_ORIGIN — exact origin used in `Access-Control-Allow-Origin`
#                     header. Required when frontend lives on a different
#                     origin. Wildcard NOT allowed with credentials.
#   COOKIE_DOMAIN   — leading dot so the cookie is shared between the
#                     bare apex and api.* subdomain.
FRONTEND_ORIGIN=https://ajelsa.net
COOKIE_DOMAIN=.ajelsa.net

# Standard
NODE_ENV=production

# ---- Object Storage (later batches) ----
# Add Cloudinary / R2 / Replit Object Storage credentials when the
# media/upload routes get ported. Not required yet.
# CLOUDINARY_URL=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_ACCOUNT_ID=
