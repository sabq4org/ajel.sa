# ajelsa (Vercel) — environment variables
#
# Public (browser-readable) variables are prefixed NEXT_PUBLIC_.

# ---- API base URL (browser → api-server) ----
# In production: https://api.ajel.sa
# In local dev pointing at a local api-server: http://localhost:8080
NEXT_PUBLIC_API_URL=https://api.ajel.sa

# ---- Auth (must match api-server's AUTH_SECRET while both sides still
# verify sessions during the cutover) ----
AUTH_SECRET=replace-with-32-or-more-random-characters
# AUTH_COOKIE_NAME=ajel_session

# ---- Database ----
# While ajelsa still owns ~unmigrated routes, it still talks to the DB
# directly. Use the same Railway Postgres connection string as api-server.
DATABASE_URL=postgresql://user:pass@host:port/db
# Optional Neon-style override (some code paths check this first):
# NEON_DATABASE_URL=

# ---- ISR revalidate webhook ----
# api-server will POST to /api/revalidate after publishing to clear the
# Next.js cache. Shared secret protects this endpoint.
REVALIDATE_SECRET=replace-with-random-secret

# ---- Standard ----
NODE_ENV=production

# ---- Image / AI / search providers (ported in later batches) ----
# CLOUDINARY_URL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# REDIS_URL=
# MEILISEARCH_HOST=
# MEILISEARCH_API_KEY=
